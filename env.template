# Переменные окружения для Sheets to WordPress Automation
# Заполните реальными значениями перед запуском.

# OpenAI API
# Ключ получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_SECOND_MODEL=gpt-4o-mini
# Для reasoning-моделей (low|medium|high)
OPENAI_TEXT_REASONING_EFFORT=
OPENAI_SECOND_REASONING_EFFORT=
# Для неризонинг-моделей (0.0 - 2.0)
OPENAI_TEXT_TEMPERATURE=
OPENAI_SECOND_TEMPERATURE=
# Путь к системным промптам (относительно run/ или абсолютный)
OPENAI_SYSTEM_PROMPT_FILE=prompts/assistant_system.txt
OPENAI_SECOND_SYSTEM_PROMPT_FILE=prompts/second_system.txt

# OpenCage Geocoding API
# Ключ получить: https://opencagedata.com/api
OPENCAGE_API_KEY=your-opencage-api-key-here

# Google Sheets
# ID таблицы берется из URL Google Sheets
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id-here
GOOGLE_WORKSHEET_NAME=RACES
# JSON сервисного аккаунта: Google Cloud Console -> IAM & Admin -> Service Accounts
GOOGLE_CREDENTIALS_FILE=google-credentials.json
# Альтернатива: полный JSON сервисного аккаунта строкой (для secret manager)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_CACHE_TTL_SEC=2700
GOOGLE_SHEETS_UPDATE_MAX_ATTEMPTS=3
GOOGLE_SHEETS_UPDATE_BASE_DELAY_SEC=1

# WordPress/WooCommerce
# URL WordPress сайта
WP_URL=https://your-wordpress-site.com
# Логин/пароль администратора WordPress
WP_ADMIN_USER=your-wp-admin-username
WP_ADMIN_PASS=your-wp-admin-password
# WooCommerce -> Settings -> Advanced -> REST API
WP_CONSUMER_KEY=ck_your-woocommerce-consumer-key
WP_CONSUMER_SECRET=cs_your-woocommerce-consumer-secret

# Настройки приложения
SKIP_AI=false
SKIP_IMAGE=true
SLEEP_SECONDS=3
# Сколько дополнительных попыток второго ассистента при отсутствии PT полей (0-2)
PT_RETRY_ATTEMPTS=2

# SSL/TLS в контейнере
SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt

# HTTP-запросы к WEBSITE/REGULATIONS
HTTP_FETCH_USER_AGENT=
# Задержки ретраев через запятую, например: 60,120
HTTP_FETCH_RETRY_DELAYS_SEC=60,120
# Точечный список хостов без SSL проверки (через запятую)
HTTP_FETCH_INSECURE_HOSTS=

# Расписание
RUN_ON_STARTUP=true
SCHEDULED_HOUR=2
SCHEDULED_MINUTE=0
TIMEZONE=Europe/Moscow

# Повторные попытки WooCommerce
WCAPI_MAX_ATTEMPTS=4
WCAPI_BASE_DELAY_SEC=1.5
WCAPI_TIMEOUT_SEC=20

# Логирование
LOG_LEVEL=INFO
LOG_FILE=/app/logs/automation.log
